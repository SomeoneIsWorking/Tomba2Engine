# Build + generated artifacts (regenerated by run.sh / ensure_recomp.py)
build/
scratch/
generated/
# Recompiled substrate + disc assets are provisioned locally, never committed
*.chd
.env
# The framework submodule's own working-tree noise
external/psxport/build/
external/psxport/scratch/
*.log

# Python bytecode — never committed (compiled .pyc embed ABSOLUTE SOURCE PATHS,
# i.e. a machine-path leak that a TEXT-only audit cannot see: they are binary).
__pycache__/
*.pyc
